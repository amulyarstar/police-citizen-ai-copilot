# Every variable below is OPTIONAL. With none set, the app runs fully in
# local demo mode: SQLite file DB, in-memory sensor store (auto-seeded),
# heuristic complaint extraction, and a mock guardrail shield.
# Add real credentials incrementally — each one independently upgrades one
# piece of the pipeline. See DEPLOY.md for where to get each of these.

# --- LLM (upgrades complaint extraction from heuristic -> real Mastra agent) ---
# Set ONE of these:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional override, defaults to anthropic/claude-sonnet-4-6 or openai/gpt-4o-mini
MASTRA_MODEL=

# --- Postgres (upgrades case + audit storage from local SQLite -> durable Postgres) ---
# Get a free instance at https://neon.tech or https://supabase.com
DATABASE_URL=

# --- Qdrant (upgrades sensor correlation from in-memory -> real vector DB) ---
# Get a free cluster at https://cloud.qdrant.io
QDRANT_URL=
QDRANT_API_KEY=

# --- Enkrypt AI (upgrades guardrails from regex mock -> real Enkrypt shields) ---
# Get a key at https://app.enkryptai.com
ENKRYPT_API_KEY=
ENKRYPT_BASE_URL=
